# Local Supabase connection (get values from `yarn supabase status`).
# iOS simulator: use 127.0.0.1. Android emulator: use 10.0.2.2.
# Physical device: use your machine's LAN IP (e.g. http://192.168.1.20:54321).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
