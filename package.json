{
  "name": "wrsi",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:backend": "yarn workspace @wrsi/backend-tests test:integration",
    "docs:api": "yarn dlx serve docs",
    "gen:types": "supabase gen types typescript --local --schema public > packages/shared-types/src/database.types.ts"
  },
  "devDependencies": {
    "supabase": "^2.109.0",
    "turbo": "^2.10.2",
    "typescript": "~6.0.3"
  }
}
